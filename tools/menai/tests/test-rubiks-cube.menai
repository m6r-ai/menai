(let ((rubiks (import "rubiks_cube")))
  (let ((solved-cube-fn (dict-get rubiks "solved-cube"))
        (apply-moves-fn (dict-get rubiks "apply-moves"))
        (ida-star-fn (dict-get rubiks "ida-star"))
        (format-solution-fn (dict-get rubiks "format-solution")))
    ; Create a solved cube and scramble it with a few moves
    (let ((cube (solved-cube-fn)))
      (let ((scrambled (apply-moves-fn cube (list "R" "U" "R'" "D"))))
        ; Try to solve it (max depth 10)
        (let ((solution (ida-star-fn scrambled 10)))
          (format-solution-fn solution))))))
